generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(cuid())
  name      String
  goal      String   @default("")
  repoUrl   String   @default("")
  prUrl     String   @default("")
  status    String   @default("idle")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sources       Source[]
  knowledge     KnowledgeSummary?
  repoAnalysis  RepoAnalysis?
  workflow      Workflow?
  releaseReport ReleaseReport?
  proofPack     ProofPack?
}

model Source {
  id         String   @id @default(cuid())
  projectId  String
  type       String
  title      String   @default("")
  rawContent String
  documentId String   @default("")
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model KnowledgeSummary {
  id                     String   @id @default(cuid())
  projectId              String   @unique
  mainTopic              String   @default("")
  keyConcepts            Json     @default("[]")
  implementationPatterns Json     @default("[]")
  buildableTasks         Json     @default("[]")
  warningsOrPitfalls     Json     @default("[]")
  termsToUnderstand      Json     @default("[]")
  sourceEvidence         Json     @default("[]")
  recommendedNextAction  String   @default("")
  rawOutput              String   @default("")
  createdAt              DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model RepoAnalysis {
  id                     String   @id @default(cuid())
  projectId              String   @unique
  repoUrl                String   @default("")
  detectedStack          Json     @default("[]")
  architectureSummary    String   @default("")
  importantFiles         Json     @default("[]")
  likelyFeatureLocations Json     @default("[]")
  testLocations          Json     @default("[]")
  setupQuality           String   @default("")
  missingItems           Json     @default("[]")
  risks                  Json     @default("[]")
  maturityScore          Int      @default(0)
  recommendedFixes       Json     @default("[]")
  rawOutput              String   @default("")
  graphJson              Json     @default("{}")
  createdAt              DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Workflow {
  id                          String   @id @default(cuid())
  projectId                   String   @unique
  title                       String   @default("")
  objective                   String   @default("")
  tasksJson                   Json     @default("[]")
  acceptanceCriteria          Json     @default("[]")
  completedAcceptanceCriteria Json     @default("[]")
  testPlan                    String   @default("")
  expectedFiles               Json     @default("[]")
  reviewChecklist             Json     @default("[]")
  rawOutput                   String   @default("")
  createdAt                   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ReleaseReport {
  id                          String   @id @default(cuid())
  projectId                   String   @unique
  releaseScore                Int      @default(0)
  decision                    String   @default("")
  topRisks                    Json     @default("[]")
  missingTests                Json     @default("[]")
  missingDocs                 Json     @default("[]")
  configOrEnvIssues           Json     @default("[]")
  backwardCompatibility       Json     @default("[]")
  releaseChecklist            Json     @default("[]")
  releaseNotesDraft           String   @default("")
  recommendedFixesBeforeMerge Json     @default("[]")
  rawOutput                   String   @default("")
  createdAt                   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProofPack {
  id                   String   @id @default(cuid())
  projectId            String   @unique
  portfolioSummary     String   @default("")
  resumeBullet         String   @default("")
  demoVideoScript      String   @default("")
  interviewExplanation String   @default("")
  linkedinPost         String   @default("")
  proofScore           Int      @default(0)
  missingProofItems    Json     @default("[]")
  rawOutput            String   @default("")
  createdAt            DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  details   String   @default("")
  projectId String   @default("")
  createdAt DateTime @default(now())
}
