# ──────────────────────────────────────────────
# Hermes Forge — Environment Configuration
# ──────────────────────────────────────────────

# Database (PostgreSQL required)
# e.g., postgresql://username:password@localhost:5432/hermes_forge or Neon DB URL
DATABASE_URL="postgresql://username:password@localhost:5432/hermes_forge"

# GitHub
# Personal access token (classic) with repo & contents scope.
# Without this, GitHub API calls are limited to 60 req/hr.
GITHUB_TOKEN=

# Lemma SDK
# Get these from https://lemma.work after creating a pod.
# When configured, agents run on Lemma's infrastructure
# instead of local rule-based execution.
LEMMA_API_KEY=
LEMMA_POD_ID=
LEMMA_BASE_URL=https://api.lemma.work

# Analysis
ANALYSIS_MAX_CONTENT_LENGTH=100000
MAX_SOURCES_PER_PROJECT=20

# OpenRouter
# Get your API key from https://openrouter.ai/keys (free, no credit card).
# When configured and Lemma is not, agents run via OpenRouter free models.
# Default model: qwen/qwen3-coder:free (best free model for structured JSON output)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-coder:free

# CORS
# Comma-separated list of allowed origins for API routes.
# Leave empty to allow all origins in development.
CORS_ORIGINS=

# Environment
NODE_ENV=development
