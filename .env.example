# ──────────────────────────────────────────────
# Nexus Forge — Environment Configuration
# ──────────────────────────────────────────────

# Database (Neon Serverless PostgreSQL)
# Get your Connection String from the Neon.tech dashboard
DATABASE_URL="postgresql://neondb_owner:xxxxxxxx@ep-xxxxxx-xxxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# GitHub
# Personal access token (classic) with repo & contents scope.
# Without this, GitHub API calls are limited to 60 req/hr.
GITHUB_TOKEN=


# Analysis
ANALYSIS_MAX_CONTENT_LENGTH=100000
MAX_SOURCES_PER_PROJECT=20

# Groq
# Get your API key from https://console.groq.com/keys
# When configured and Lemma is not, agents run via Groq's high-speed models.
# Default model: llama-3.3-70b-versatile
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# CORS
# Comma-separated list of allowed origins for API routes.
# Leave empty to allow all origins in development.
CORS_ORIGINS=

# Environment
NODE_ENV=development
