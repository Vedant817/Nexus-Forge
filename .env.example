# ──────────────────────────────────────────────
# Praxis Forge — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file as a starting point. In production,
# set these via your hosting platform's env system.
# ──────────────────────────────────────────────

# Database
# SQLite file path. For production, replace with a
# hosted PostgreSQL/MySQL URL and update the Prisma
# provider + adapter in src/lib/db/prisma.ts.
DATABASE_URL="file:./praxis-forge.db"

# GitHub
# Personal access token (classic) with repo & contents
# scope. Without this, GitHub API calls are limited
# to 60 requests/hour (unauthenticated).
GITHUB_TOKEN=

# Analysis
# Max content size in characters for a single source
ANALYSIS_MAX_CONTENT_LENGTH=100000
# Maximum number of sources per project
MAX_SOURCES_PER_PROJECT=20

# Environment
# Set to "production" for production deployments
NODE_ENV=development
